# Reel Atlas — environment configuration
# Copy this to .env and fill in values.
# Bun loads .env natively — no dotenv package needed.

# ── Storage ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
DB_PATH=./reel-atlas.db

# Directory for downloaded media files (video, audio, keyframes).
# git-ignored; will be created automatically by the worker.
MEDIA_DIR=./media

# ── Drop-folder watcher (CAP-02) ─────────────────────────────────────────────
# Directory to watch for dropped video files (plan 01-02).
# DROP_DIR=./drop

# ── Instagram download (ING-01) ──────────────────────────────────────────────
# Browser whose cookie store yt-dlp reads for Instagram auth.
# Chrome must be CLOSED when running the worker (Chrome locks its cookie DB).
# Supported: brave, chrome, chromium, edge, firefox, opera, safari, vivaldi, whale
IG_COOKIES_BROWSER=chrome

# ── Local HTTP intake (CAP-01, plan 01-02) ───────────────────────────────────
# Port for the local HTTP endpoint (binds to 127.0.0.1 only).
# HTTP_PORT=3000

# ── Opt-in saved-collection sync (CAP-05, plan 01-03) ────────────────────────
# Off by default. Set SYNC_ENABLED=true and configure your collection URL.
SYNC_ENABLED=false
# SYNC_COLLECTION_URL=https://www.instagram.com/USERNAME/saved/COLLECTION-NAME/12345678
SYNC_BATCH_SIZE=10
SYNC_DELAY_MIN_MS=8000
SYNC_DELAY_MAX_MS=25000
# SYNC_CRON="0 */2 * * *"

# ── Phase 2 enrichment (not used in Phase 1) ─────────────────────────────────
# GROQ_API_KEY=gsk_...
# GROQ_WHISPER_MODEL=whisper-large-v3
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-5
